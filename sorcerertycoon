local function getNearbyEnemies()
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end
    local e = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        local hum = obj:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            local isP = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == obj then isP = true break end
            end
            if not isP then
                local enemyHRP = obj:FindFirstChild("HumanoidRootPart")
                if enemyHRP then
                    local dist = (hrp.Position - enemyHRP.Position).Magnitude
                    if dist <= KILL_RADIUS then
                        table.insert(e, obj)
                    end
                end
            end
        end
    end
    return e
end

local function startKill()
    if autoKillLoop then return end
    autoKillLoop = true
    task.spawn(function()
        while autoKill do
            local enemies = getNearbyEnemies()
            if #enemies == 0 then
                kStatus.Text = "⏳ No enemies nearby..."
                kStatus.TextColor3 = C_GOLD
            else
                kStatus.Text = "⚔ Attacking "..#enemies.." enemies"
                kStatus.TextColor3 = C_RED
                for _, enemy in ipairs(enemies) do
                    if not autoKill then break end
                    local hum = enemy:FindFirstChildOfClass("Humanoid")
                    if not hum or hum.Health <= 0 then continue end
                    pcall(function() SKill:FireServer(CHARACTER, "M1_1") end)
                    pcall(function()
                        local id = tostring(math.random(100000,999999)).."_hit1"
                        ReportHits:FireServer(id, {{characterName=enemy.Name}})
                    end)
                    killCount += 1
                    kCount.Text = "Hits: "..killCount
                end
            end
            task.wait(ATTACK_INTERVAL)
        end
        autoKillLoop = false
        kStatus.Text = "Status: Idle"
        kStatus.TextColor3 = C_DIM
    end)
end

