local charBtns = {}
for i, name in ipairs(chars) do
    local row = math.ceil(i/2)
    local col = (i-1) % 2
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.46,0,0,30)
    btn.Position = UDim2.new(col*0.5+0.02,0,0,32+(row-1)*36)
    btn.BackgroundColor3 = name==CHARACTER and Color3.fromRGB(20,35,60) or Color3.fromRGB(22,22,32)
    btn.Text = name
    btn.TextColor3 = name==CHARACTER and C_BLUE or C_DIM
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.Parent = CChar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
    local bs = Instance.new("UIStroke", btn)
    bs.Color = name==CHARACTER and C_BLUE or Color3.fromRGB(40,40,55)
    bs.Thickness = 1
    charBtns[name] = btn
    local cap = name
    btn.MouseButton1Click:Connect(function()
        CHARACTER = cap
        curCharLbl.Text = "Current: "..cap
        for n, b in pairs(charBtns) do
            b.BackgroundColor3 = n==cap and Color3.fromRGB(20,35,60) or Color3.fromRGB(22,22,32)
            b.TextColor3 = n==cap and C_BLUE or C_DIM
            local s = b:FindFirstChildOfClass("UIStroke")
            if s then s.Color = n==cap and C_BLUE or Color3.fromRGB(40,40,55) end
        end
    end)
end

