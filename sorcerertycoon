local function startRoll()
    if autoRollLoop then return end
    autoRollLoop = true
    task.spawn(function()
        while autoRoll do
            local found = false
            for _, obj in ipairs(workspace:GetDescendants()) do
                -- FIX: ActionText starts with "Roll"
                if obj:IsA("ProximityPrompt") and obj.ActionText:sub(1,4) == "Roll" then
                    pcall(function() fireproximityprompt(obj) end)
                    found = true
                    rollCount += 1
                    sCount.Text = "Rolls: "..rollCount
                    sStatus.Text = "🎰 Rolling..."
                    sStatus.TextColor3 = C_ORANGE
                    break
                end
            end
            if not found then
                sStatus.Text = "⏳ Roll prompt not found..."
                sStatus.TextColor3 = C_GOLD
            end
            task.wait(ROLL_INTERVAL)
        end
        autoRollLoop = false
        sStatus.Text = "Status: Idle"
        sStatus.TextColor3 = C_DIM
    end)
end

